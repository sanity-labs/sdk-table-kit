{
  "name": "@sanity-labs/sdk-table-kit",
  "version": "0.0.1",
  "private": false,
  "description": "Sanity SDK integration layer for @sanity-labs/react-table-kit.",
  "keywords": [
    "react",
    "sanity",
    "sanity-labs",
    "sdk",
    "table"
  ],
  "homepage": "https://github.com/sanity-labs/sdk-table-kit#readme",
  "bugs": {
    "url": "https://github.com/sanity-labs/sdk-table-kit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sanity-labs/sdk-table-kit.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "build:watch": "tsdown --config tsdown.config.ts --watch",
    "format": "oxfmt package.json tsconfig.json tsconfig.build.json tsdown.config.ts vitest.config.component.ts vitest.setup.ts src __tests__ __mocks__",
    "format:check": "oxfmt --check package.json tsconfig.json tsconfig.build.json tsdown.config.ts vitest.config.component.ts vitest.setup.ts src __tests__ __mocks__",
    "lint": "oxlint src __tests__ __mocks__ tsdown.config.ts vitest.config.component.ts vitest.setup.ts",
    "test": "vitest run --config vitest.config.component.ts",
    "test:watch": "vitest --config vitest.config.component.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@portabletext/react": "^6.0.3",
    "@sanity-labs/react-table-kit": "file:../react-table-kit",
    "@sanity-labs/sdk-addon-dataset-runtime": "^1.0.0",
    "@sanity-labs/sdk-comments": "^1.0.0",
    "@sanity-labs/sdk-tasks": "^1.0.0",
    "lodash-es": "^4.17.23",
    "lucide-react": "^1.7.0",
    "slate": "^0.124.0",
    "slate-react": "^0.124.0"
  },
  "devDependencies": {
    "@sanity/icons": "^3.7.4",
    "@sanity/sdk": "^2.8.0",
    "@sanity/sdk-react": "^2.8.0",
    "@sanity/types": "^5.18.0",
    "@sanity/ui": "^3.1.11",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^24.0.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^26.0.0",
    "nuqs": "^2.8.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "react": "^19.0.0",
    "react-day-picker": "^9.7.0",
    "react-dom": "^19.0.0",
    "styled-components": "^6.1.18",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@sanity/icons": "^3.0.0",
    "@sanity/sdk": "^2.0.0",
    "@sanity/sdk-react": "^2.0.0",
    "@sanity/types": "^3.0.0 || ^4.0.0 || ^5.0.0",
    "@sanity/ui": "^3.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "packageManager": "pnpm@10.32.1"
}
